            </geometry>
            <material name="Black"/>
        </visual>
        <collision name="wheel_left_collision">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="../meshes/wheel_left.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>

    <link name="wheel_rigth">
        <inertial>
            <origin xyz="0 0 1.819e-3" rpy="0.0 -0.0 0.0" />
            <mass value="2.91188" />
            <inertia ixx="3.948e-03" iyy="3.948e-03" izz="6.576e-03" ixy="-11.421e-09" iyz="10.676e-09" ixz="9.896e-09" />
        </inertial>
        <visual name="wheel_rigth_visual">
            <origin xyz="0 0 0" rpy="0 0 0" />
