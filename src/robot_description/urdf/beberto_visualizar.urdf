    </link>




    <joint name="base_link_wheel_left_joint" type="continuous">
        <origin xyz="69.75e-03 -163.00e-03 -83.008e-3" rpy="-1.5707963267948968 0 0" />
        <parent link="base_link" />
        <child link="wheel_left" />
        <axis xyz="0 0 1" />
    </joint>

    <joint name="base_link_wheel_rigth_joint" type="continuous">
        <origin xyz="69.75e-03 163.00e-03 -83.008e-3" rpy="-1.5707963267948968 0 0" />
        <parent link="base_link" />
        <child link="wheel_rigth" />
        <axis xyz="0 0 1" />
    </joint>

    <joint name="base_link_rotatori_suport_left_joint" type="continuous">
        <origin xyz="-135e-03 -115e-03 -93e-03" rpy="0 3.141592653589793 0" />
        <parent link="base_link" />
        <child link="rotatori_suport_left" />
        <axis xyz="0 0 1" />
    </joint>

    <joint name="base_link_rotatori_suport_rigth_joint" type="continuous">
        <origin xyz="-135e-03 115e-03 -93e-03" rpy="0 3.141592653589793 0" />
        <parent link="base_link" />
        <child link="rotatori_suport_rigth" />
        <axis xyz="0 0 1" />
    </joint>

    <joint name="base_link_road_left_joint" type="continuous">
        <origin xyz="25e-03 0 45.5e-03" rpy="-1.5707963267948968 3.141592653589793 0" />
        <parent link="rotatori_suport_left" />
        <child link="road_left" />
        <axis xyz="0 0 1" />
    </joint>

    <joint name="base_link_road_rigth_joint" type="continuous">
        <origin xyz="25e-03 0 45.5e-03" rpy="-1.5707963267948968 3.141592653589793 0" />
        <parent link="rotatori_suport_rigth" />
        <child link="road_rigth" />
        <axis xyz="0 0 1" />
    </joint>


</robot>