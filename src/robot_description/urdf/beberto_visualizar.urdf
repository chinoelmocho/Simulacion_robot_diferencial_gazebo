            <geometry>
                <mesh filename="../meshes/rotatory_suport_rigth.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>


     <link name="road_left">
        <inertial>
            <origin xyz="0 0 0" rpy="0.0 -0.0 0.0" />
            <mass value="82.503e-03" />
            <inertia ixx="13380.147e-09" iyy="13380.149e-09" izz="17712.794" ixy="0" iyz="0" ixz="0" />
        </inertial>
        <visual name="road_left_visual">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="../meshes/road_left.stl" scale="0.001 0.001 0.001" />
            </geometry>
